{
  "name": "playground-nuxt",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "clean": "rimraf node_modules .nuxt .output",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "lint": "eslint --fix .",
    "lint:check": "eslint .",
    "prepare": "nuxt prepare",
    "preview": "nuxt preview",
    "type-check": "run-s type-check:main type-check:tools",
    "type-check:main": "tsc --noEmit",
    "type-check:tools": "tsc --noEmit -p tsconfig.tools.json"
  },
  "dependencies": {
    "nuxt": "^4.4.7",
    "vue": "^3.5.16",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@nuxt/eslint": "^1.15.2",
    "@poupe/eslint-config": "workspace:^",
    "eslint": "^10.4.1",
    "npm-run-all2": "^8.0.4",
    "rimraf": "^6.1.3"
  }
}
