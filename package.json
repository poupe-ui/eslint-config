{
  "name": "@poupe/eslint-config",
  "version": "0.8.4",
  "type": "module",
  "description": "Sharable ESLint configuration preset for Poupe UI projects with TypeScript, Vue.js, and Tailwind CSS support",
  "author": "Alejandro Mery <amery@apptly.co>",
  "license": "MIT",
  "homepage": "https://github.com/poupe-ui/eslint-config",
  "repository": "github:poupe-ui/eslint-config",
  "bugs": "https://github.com/poupe-ui/eslint-config/issues",
  "keywords": [
    "eslint",
    "eslintconfig",
    "eslint-config",
    "flat-config",
    "typescript",
    "vue",
    "css",
    "tailwindcss",
    "markdown",
    "json",
    "stylistic",
    "unicorn",
    "perfectionist",
    "tsdoc"
  ],
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "unbuild",
    "clean": "pnpm -r --filter \"./examples/*\" clean && rimraf dist node_modules",
    "dev:prepare": "unbuild --stub",
    "lint": "run-s prepare lint:_fix",
    "lint:_fix": "eslint --fix .",
    "lint:all": "run-s prepare lint:_fix lint:examples",
    "lint:all:check": "run-s prepare lint:check lint:examples:check",
    "lint:check": "eslint .",
    "lint:examples": "pnpm -r --filter \"playground-*\" lint",
    "lint:examples:check": "pnpm -r --filter \"playground-*\" lint:check",
    "precommit": "run-s build lint:all type-check test:all",
    "prepack": "eslint --fix package.json && run-s build lint:all:check type-check test:all publint",
    "prepare": "cross-test -s dist/index.mjs || unbuild --stub",
    "publint": "publint",
    "test": "pnpm -r dev:prepare && node test/config.test.mjs",
    "test:all": "run-s test:unit test",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest watch",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@eslint/css": "^1.0.0",
    "@eslint/js": "^9.39.4",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@typescript-eslint/parser": "^8.57.2",
    "@vue/eslint-config-typescript": "^14.7.0",
    "eslint": "^9.39.4",
    "eslint-plugin-jsonc": "^3.1.2",
    "eslint-plugin-markdownlint": "^0.9.0",
    "eslint-plugin-perfectionist": "^4.15.1",
    "eslint-plugin-tsdoc": "^0.5.2",
    "eslint-plugin-unicorn": "^63.0.0",
    "eslint-plugin-vue": "^10.8.0",
    "tailwind-csstree": "~0.3.0",
    "typescript-eslint": "^8.57.2"
  },
  "devDependencies": {
    "@kagal/cross-test": "~0.1.3",
    "@vitest/ui": "~4.0.18",
    "eslint-flat-config-utils": "^3.0.2",
    "globals": "~17.4.0",
    "npm-run-all2": "^8.0.4",
    "pkg-pr-new": "~0.0.66",
    "publint": "^0.3.18",
    "rimraf": "^6.1.3",
    "typescript": "~5.9.3",
    "unbuild": "~3.6.1",
    "vitest": "~4.0.18"
  },
  "pnpm": {
    "overrides": {
      "oxc-parser": "0.116.0"
    }
  },
  "engines": {
    "node": ">= 20.19.0",
    "pnpm": ">= 10.33.0"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
