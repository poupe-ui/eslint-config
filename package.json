{
  "name": "@poupe/eslint-config",
  "version": "0.10.1",
  "type": "module",
  "description": "Sharable ESLint configuration preset for Poupe UI projects with TypeScript, Vue.js, and Tailwind CSS support",
  "author": "Alejandro Mery <amery@apptly.co>",
  "license": "MIT",
  "homepage": "https://github.com/poupe-ui/eslint-config",
  "repository": "github:poupe-ui/eslint-config",
  "bugs": "https://github.com/poupe-ui/eslint-config/issues",
  "keywords": [
    "eslint",
    "eslintconfig",
    "eslint-config",
    "flat-config",
    "typescript",
    "vue",
    "css",
    "tailwindcss",
    "markdown",
    "json",
    "stylistic",
    "unicorn",
    "perfectionist",
    "tsdoc"
  ],
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "unbuild",
    "clean": "pnpm -r clean && rimraf dist node_modules",
    "dev:prepare": "unbuild --stub",
    "dev:prepare:examples": "pnpm -r dev:prepare",
    "lint": "run-s prepare lint:_fix",
    "lint:_fix": "eslint --fix .",
    "lint:_pkg-pr-new": "eslint --fix package.json",
    "lint:all": "run-s prepare lint:_fix lint:examples",
    "lint:all:check": "run-s prepare lint:check lint:examples:check",
    "lint:check": "eslint .",
    "lint:examples": "pnpm -r lint",
    "lint:examples:check": "pnpm -r lint:check",
    "precommit": "run-s dev:prepare lint:all type-check:all build test:compat test",
    "prepack": "run-s lint:_pkg-pr-new build lint:all:check type-check:all test:compat test publint",
    "prepare": "cross-test -s dist/index.mjs || pnpm dev:prepare",
    "publint": "publint",
    "test": "run-s dev:prepare:examples test:unit test:config",
    "test:compat": "node src/__tests__/compat.mjs",
    "test:config": "node src/__tests__/config.mjs",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest watch",
    "type-check": "tsc --noEmit",
    "type-check:all": "run-s type-check type-check:examples",
    "type-check:examples": "pnpm -r type-check"
  },
  "dependencies": {
    "@eslint/css": "^1.3.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@typescript-eslint/parser": "^8.62.1",
    "eslint-merge-processors": "^2.0.0",
    "eslint-plugin-jsonc": "^3.1.2",
    "eslint-plugin-markdownlint": "^0.10.1",
    "eslint-plugin-perfectionist": "^5.8.0",
    "eslint-plugin-tsdoc": "^0.5.2",
    "eslint-plugin-unicorn": "^63.0.0",
    "eslint-plugin-vue": "^10.8.0",
    "eslint-processor-vue-blocks": "^2.0.0",
    "tailwind-csstree": "^0.3.0",
    "typescript-eslint": "^8.62.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@kagal/build-tsdoc": "^0.2.0",
    "@kagal/cross-test": "^0.1.3",
    "@vitest/ui": "^4.1.3",
    "eslint": "^10.5.0",
    "npm-run-all2": "^8.0.4",
    "pkg-pr-new": "~0.0.75",
    "publint": "^0.3.18",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "unbuild": "^3.6.1",
    "vitest": "^4.1.3"
  },
  "peerDependencies": {
    "@eslint/js": "^9.39.4 || ^10",
    "@vue/compiler-sfc": "^3.5.39",
    "eslint": "^9.39.4 || ^10",
    "typescript": ">=5.9.0 <6.1.0"
  },
  "engines": {
    "node": "^20.19.0 || ^22.13.0 || >=24",
    "pnpm": ">= 10.33.0"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "pnpm": {
    "overrides": {
      "@typescript-eslint/utils": "^8.62.1"
    }
  }
}
