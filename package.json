{
  "name": "@poupe/eslint-config",
  "version": "0.8.2",
  "type": "module",
  "description": "Sharable ESLint configuration preset for Poupe UI projects with TypeScript, Vue.js, and Tailwind CSS support",
  "author": "Alejandro Mery <amery@apptly.co>",
  "license": "MIT",
  "homepage": "https://github.com/poupe-ui/eslint-config",
  "repository": "github:poupe-ui/eslint-config",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./nuxt": {
      "import": "./dist/nuxt.mjs",
      "require": "./dist/nuxt.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "unbuild",
    "clean": "pnpm -r --filter \"./examples/*\" clean && rimraf dist node_modules",
    "dev:prepare": "unbuild --stub",
    "lint": "run-s prepare lint:_fix",
    "lint:_fix": "eslint --fix .",
    "lint:all": "run-s prepare lint:_fix lint:examples",
    "lint:all:check": "run-s prepare lint:check lint:examples:check",
    "lint:check": "eslint .",
    "lint:examples": "pnpm -r --filter \"playground-*\" lint",
    "lint:examples:check": "pnpm -r --filter \"playground-*\" lint:check",
    "precommit": "run-s lint:all type-check test:all build",
    "prepack": "run-s lint:all:check type-check test:all build publint",
    "prepare": "cross-test -s dist/index.mjs || unbuild --stub",
    "publint": "publint",
    "test": "pnpm -r dev:prepare && node test/config.test.mjs",
    "test:all": "run-s test:unit test",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest watch",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@eslint/css": "~0.14.1",
    "@eslint/js": "^9.39.3",
    "@stylistic/eslint-plugin": "^5.9.0",
    "@typescript-eslint/parser": "^8.56.1",
    "@vue/eslint-config-typescript": "^14.7.0",
    "eslint": "^9.39.3",
    "eslint-plugin-jsonc": "^3.1.1",
    "eslint-plugin-markdownlint": "^0.9.0",
    "eslint-plugin-perfectionist": "^4.15.1",
    "eslint-plugin-tsdoc": "^0.5.2",
    "eslint-plugin-unicorn": "^63.0.0",
    "eslint-plugin-vue": "^10.8.0",
    "tailwind-csstree": "~0.1.4",
    "typescript-eslint": "^8.56.1"
  },
  "devDependencies": {
    "@kagal/cross-test": "~0.1.0",
    "@vitest/ui": "~4.0.18",
    "eslint-flat-config-utils": "^3.0.2",
    "globals": "~17.4.0",
    "npm-run-all2": "^8.0.4",
    "pkg-pr-new": "~0.0.65",
    "publint": "^0.3.18",
    "rimraf": "^6.1.3",
    "typescript": "~5.9.3",
    "unbuild": "~3.6.1",
    "vitest": "~4.0.18"
  },
  "pnpm": {
    "overrides": {
      "oxc-parser": "0.116.0"
    }
  },
  "engines": {
    "node": ">= 20.19.0",
    "pnpm": ">= 10.30.3"
  },
  "packageManager": "pnpm@10.30.3+sha512.c961d1e0a2d8e354ecaa5166b822516668b7f44cb5bd95122d590dd81922f606f5473b6d23ec4a5be05e7fcd18e8488d47d978bbe981872f1145d06e9a740017"
}
